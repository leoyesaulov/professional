{
	auto_https off
}

http://localhost:5005 {
	@notData {
		not path /.git/*
		not path /Caddyfile
		not path /Dockerfile
		not path /.vscode/*
		not path /.idea/*
		not path /.env
		not path /hidden/*
	}
	
	output logger_out /hidden/caddylog {
		mode 600
		roll_interval 30d
	}

	log {
		output logger_out
		format console
	}



	respond /.git/* 403
	respond /Caddyfile 403
	respond /Dockerfile 403
	respond /.vscode/* 403
	respond /.idea/* 403
	respond /.env 403
	respond /hidden/* 403

	file_server @notData
}
